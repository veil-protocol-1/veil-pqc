{
  "name": "@veil_/x402-pqc",
  "version": "1.0.1",
  "description": "Quantum-resistant x402 payment protocol — ML-DSA-65 signing + ML-KEM-768 encryption + session mode",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": ["dist", "README.md", "LICENSE"],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@veil_/pqc-wallet": "^1.0.0",
    "@noble/hashes": "^1.6.0",
    "@noble/ciphers": "^1.0.0",
    "@noble/post-quantum": "^0.2.1"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^2.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "x402",
    "post-quantum",
    "ml-dsa",
    "ml-kem",
    "payment",
    "pqc",
    "ai-agents",
    "quantum-resistant"
  ]
}
